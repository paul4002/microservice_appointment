RABBITMQ_PUBLISH_BACKOFF_MS=250
RABBITMQ_CONNECT_TIMEOUT=3
RABBITMQ_READ_WRITE_TIMEOUT=3
RABBITMQ_OUTBOX_BATCH_SIZE=50
RABBITMQ_OUTBOX_POLL_INTERVAL_MS=5000


INBOUND_SCHEMA_VERSIONS=1
INBOUND_RABBITMQ_ENABLED=true
